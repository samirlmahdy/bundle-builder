{
  "name": "test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names api,web \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.mjs",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "node server/index.mjs",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "express": "^5.2.1",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
